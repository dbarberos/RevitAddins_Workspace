<Window x:Class="KreanRender.Views.RenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KreanRender - Vista" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Options -->
            <RowDefinition Height="*"/>    <!-- Images -->
            <RowDefinition Height="Auto"/> <!-- Status & Render Button -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Generación de Render Fotorrealista" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
            
            <CheckBox x:Name="UseGeminiCheckBox" Content="Usar API de Gemini (saltar modelo local)" Margin="0,5" Checked="UseGeminiCheckBox_Changed" Unchecked="UseGeminiCheckBox_Changed" />
            
            <StackPanel x:Name="GeminiKeyPanel" Orientation="Horizontal" Margin="0,5" Visibility="Collapsed">
                <TextBlock Text="API Key de Gemini:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox x:Name="GeminiKeyTextBox" Width="300"/>
            </StackPanel>

            <TextBlock Text="Prompt del renderizado:" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <TextBox x:Name="PromptTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,10"/>
            
            <TextBlock Text="Materiales detectados:" Margin="0,0,0,0" FontWeight="SemiBold"/>
            <TextBlock x:Name="MaterialsTextBlock" Foreground="DarkSlateGray" TextWrapping="Wrap" Margin="0,5,0,10" Text="Extrayendo materiales..." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Vista Original" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border BorderBrush="LightGray" BorderThickness="1" Background="#f0f0f0" Height="250">
                    <Image x:Name="OriginalImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Vista Renderizada" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border BorderBrush="LightGray" BorderThickness="1" Background="#f0f0f0" Height="250">
                    <Image x:Name="RenderedImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <TextBlock x:Name="StatusText" Text="Esperando configuración..." VerticalAlignment="Center" Foreground="Gray"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseButton" Content="Cerrar" Width="100" Height="30" Margin="0,0,10,0" Click="CloseButton_Click"/>
                <Button x:Name="RenderButton" Content="Renderizar" Width="120" Height="30" Click="RenderButton_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
