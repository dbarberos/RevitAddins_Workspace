<Window x:Class="KreanRenderLocal.Views.RenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KreanRender - Vista" 
        Height="650" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header & Options -->
            <RowDefinition Height="*"/>    <!-- Images -->
            <RowDefinition Height="Auto"/> <!-- Status & Render Button -->
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Generación de Render Fotorrealista" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
            
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Carpeta de Instalación de Modelos (Gigabytes!):" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,5"/>
                    <TextBox x:Name="LocalPathTextBox" Height="30" Padding="5" VerticalContentAlignment="Center" IsReadOnly="True" Text="Selecciona una carpeta con espacio suficiente..." />
                </StackPanel>
                <Button Grid.Column="1" x:Name="BrowseButton" Content="📁 Buscar" Width="80" Height="30" Margin="10,20,0,0" Click="BrowseButton_Click" Background="#2196F3" Foreground="White"/>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Estado del Motor:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock x:Name="EngineStatusText" Text="No inicializado" Foreground="Red" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button x:Name="PurgeButton" Content="🗑️ Desinstalar y Limpiar Espacio" Margin="20,0,0,0" Padding="10,2" Click="PurgeButton_Click" Background="#F44336" Foreground="White" ToolTip="Borra todos los Gigabytes descargados de la carpeta seleccionada."/>
            </StackPanel>

            <TextBlock Text="Prompt del renderizado:" Margin="0,5,0,0" FontWeight="SemiBold"/>
            <TextBox x:Name="PromptTextBox" Height="70" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,10"/>
            
            <TextBlock Text="Materiales detectados:" Margin="0,0,0,0" FontWeight="SemiBold"/>
            <TextBlock x:Name="MaterialsTextBlock" Foreground="DarkSlateGray" TextWrapping="Wrap" Margin="0,5,0,10" Text="Extrayendo materiales..." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Vista Original" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border BorderBrush="LightGray" BorderThickness="1" Background="#f0f0f0" Height="250">
                    <Image x:Name="OriginalImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
            
            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Vista Renderizada" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <Border BorderBrush="LightGray" BorderThickness="1" Background="#f0f0f0" Height="250">
                    <Image x:Name="RenderedImage" Stretch="Uniform" />
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <TextBlock x:Name="StatusText" Text="Esperando configuración..." VerticalAlignment="Center" Foreground="Gray"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CloseButton" Content="Cerrar" Width="100" Height="30" Margin="0,0,10,0" Click="CloseButton_Click"/>
                <Button x:Name="RenderButton" Content="Renderizar" Width="120" Height="30" Click="RenderButton_Click" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
