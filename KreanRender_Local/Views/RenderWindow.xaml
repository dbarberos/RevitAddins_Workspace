<Window x:Class="KreanRenderLocal.Views.RenderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KreanRender Local - Control Profesional" 
        Height="800" Width="850"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- 0: Header & Setup -->
            <RowDefinition Height="Auto"/> <!-- 1: Advanced Controls -->
            <RowDefinition Height="2*"/>   <!-- 2: Images -->
            <RowDefinition Height="Auto"/> <!-- 3: Splitter -->
            <RowDefinition Height="*"/>    <!-- 4: Logs Console -->
            <RowDefinition Height="Auto"/> <!-- 5: Status & Actions -->
        </Grid.RowDefinitions>

        <!-- Cabecera y Configuración Base -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Generación de Render Fotorrealista (Local Engine)" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,5,0" Background="#F9F9F9">
                    <StackPanel>
                        <Button x:Name="AnalyzeButton" Content="🔍 1. Analizar Hardware" Height="30" Click="AnalyzeButton_Click" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                        <TextBlock x:Name="HardwareInfoText" Margin="0,5,0,0" Text="Inicia el escaneo..." TextWrapping="Wrap" FontSize="11" Foreground="#555"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="5,0,0,0" Background="#F9F9F9">
                    <StackPanel>
                        <TextBlock Text="Motor IA Seleccionado:" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ModelSelector" Height="25" IsEnabled="False" SelectionChanged="ModelSelector_SelectionChanged">
                            <ComboBoxItem Content="SD 1.5 Base (4.0 GB) [Recomendado]" IsSelected="True"/>
                            <ComboBoxItem Content="Architecture Realism (4.2 GB)"/>
                            <ComboBoxItem Content="Juggernaut XL (6.9 GB)"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Prompt del Render:" FontWeight="SemiBold" FontSize="11"/>
                    <TextBox x:Name="PromptTextBox" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,5,0,0" Padding="5"/>
                    
                    <TextBlock Text="Materiales Detectados:" FontWeight="SemiBold" FontSize="11" Margin="0,10,0,5"/>
                    <TextBlock x:Name="MaterialsTextBlock" Text="Ninguno..." FontSize="10" Foreground="#666" TextWrapping="Wrap"/>

                    <TextBlock Text="Carpeta de Instalación:" FontWeight="SemiBold" FontSize="11" Margin="0,10,0,0"/>
                    <TextBox x:Name="LocalPathTextBox" Height="25" IsReadOnly="True" Background="#EEE" VerticalContentAlignment="Center" Padding="5,0"/>
                </StackPanel>
                <Button Grid.Column="1" x:Name="BrowseButton" Content="📁 Buscar" Width="80" Height="25" Margin="10,15,0,0" Click="BrowseButton_Click" IsEnabled="False" VerticalAlignment="Bottom"/>
            </Grid>
        </StackPanel>

        <!-- Status Bar superior (No bloqueante) -->
        <TextBlock x:Name="StatusText" Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Right" FontSize="10" Foreground="#888" Margin="0,5,5,0" IsHitTestVisible="False"/>

        <!-- PASO 3: AJUSTES AVANZADOS -->
        <GroupBox Grid.Row="1" Header="Ajustes de Optimización y Estilo" Margin="0,0,0,10" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Columna 1: Sliders -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <DockPanel LastChildFill="True" Margin="0,0,0,5">
                        <TextBlock Text="Steps (Calidad):" Width="100" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Value, ElementName=StepsSlider}" Width="30" TextAlignment="Right" DockPanel.Dock="Right"/>
                        <Slider x:Name="StepsSlider" Minimum="1" Maximum="50" Value="25" TickFrequency="1" IsSnapToTickEnabled="True"/>
                    </DockPanel>

                    <DockPanel LastChildFill="True" Margin="0,0,0,5">
                        <TextBlock Text="Guidance Scale:" Width="100" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Value, ElementName=GuidanceSlider, StringFormat=F1}" Width="30" TextAlignment="Right" DockPanel.Dock="Right"/>
                        <Slider x:Name="GuidanceSlider" Minimum="1" Maximum="15" Value="7.5" TickFrequency="0.5" IsSnapToTickEnabled="True"/>
                    </DockPanel>

                    <DockPanel LastChildFill="True">
                        <TextBlock Text="Geometría (CN):" Width="100" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Value, ElementName=StrengthSlider, StringFormat=F2}" Width="30" TextAlignment="Right" DockPanel.Dock="Right"/>
                        <Slider x:Name="StrengthSlider" Minimum="0.1" Maximum="1.0" Value="0.8" TickFrequency="0.05" IsSnapToTickEnabled="True"/>
                    </DockPanel>
                </StackPanel>

                <!-- Columna 2: Negative Prompt & Info -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Negative Prompt (Evitar):" FontWeight="SemiBold" FontSize="11"/>
                    <TextBox x:Name="NegativePromptTextBox" Height="45" TextWrapping="Wrap" AcceptsReturn="True" FontSize="10" Margin="0,5,0,0" 
                             Text="low quality, bad resolution, distorted, blurry, artifacts, messy lines, abstract"/>
                </StackPanel>

                <!-- Botón de Instalación -->
                <Button Grid.Row="2" Grid.ColumnSpan="2" x:Name="InstallButton" Content="📥 Instalar / Actualizar Motor Seleccionado" Height="30" Margin="0,10,0,0" Click="InstallButton_Click" IsEnabled="False" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                <ProgressBar Grid.Row="2" Grid.ColumnSpan="2" x:Name="InstallProgressBar" Height="5" VerticalAlignment="Bottom" Visibility="Collapsed"/>
            </Grid>
        </GroupBox>

        <!-- Area de Imagen -->
        <Grid Grid.Row="2" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,5,0">
                <TextBlock Text="Captura Revit" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,5"/>
                <Border BorderBrush="#CCC" BorderThickness="1" Height="220">
                    <Image x:Name="OriginalImage" Stretch="Uniform"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                <TextBlock Text="Resultado IA" HorizontalAlignment="Center" FontSize="11" Margin="0,0,0,5"/>
                <Border BorderBrush="#CCC" BorderThickness="1" Height="220" Background="#FAFAFA">
                    <Image x:Name="RenderedImage" Stretch="Uniform"/>
                </Border>
                <Button x:Name="SaveResultButton" Content="💾 GUARDAR RENDER..." Height="30" Margin="0,5,0,0" IsEnabled="False" Click="SaveResultButton_Click" Background="#E3F2FD" FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- Divisor redimensionable -->
        <GridSplitter Grid.Row="3" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="#EEE" Margin="0,5"/>

        <!-- Consola de Logs -->
        <GroupBox Grid.Row="4" Header="Consola de Proceso y Logs" Margin="0,5,0,0">
            <TextBox x:Name="LogTextBox" IsReadOnly="True" VerticalScrollBarVisibility="Auto" Background="#222" Foreground="#00FF00" 
                     FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" AcceptsReturn="True" Text="[LOG] Esperando inicio del proceso...&#x0a;"/>
        </GroupBox>

        <!-- Pie de página: Acciones -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de Progreso de Renderizado -->
            <StackPanel Grid.Row="0" Margin="0,0,0,10" x:Name="RenderProgressPanel" Visibility="Collapsed">
                <DockPanel LastChildFill="True">
                    <TextBlock x:Name="RenderPercentText" Text="0%" Width="40" FontSize="10" VerticalAlignment="Center" DockPanel.Dock="Right" TextAlignment="Right"/>
                    <ProgressBar x:Name="RenderProgressBar" Height="10" Minimum="0" Maximum="100" Value="0" Foreground="#FF9800" Background="#EEE"/>
                </DockPanel>
                <TextBlock Text="Calculando difusión de imagen..." FontSize="9" Foreground="#888" HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="InstallStatusText" Text="Estado..." Foreground="Gray" FontSize="11"/>
            </StackPanel>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="PurgeButton" Content="🗑️" Width="30" Height="35" Click="PurgeButton_Click" IsEnabled="False" ToolTip="Borrar modelos"/>
                <Button x:Name="FastRenderButton" Content="⚡ RÁPIDO" Width="100" Height="35" Margin="10,0,10,0" Click="FastRenderButton_Click" IsEnabled="False" Background="#FFEB3B" FontWeight="Bold"/>
                <Button x:Name="RenderButton" Content="🚀 RENDER FINAL" Width="150" Height="35" Click="RenderButton_Click" IsEnabled="False" Background="#FF9800" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
