<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" 
             Name="FilterPlus" 
             Language="1033" 
             Version="1.0.0.0" 
             Manufacturer="DabaDev" 
             UpgradeCode="5E7F46B1-A7D4-4E8B-B0D1-1C9C8B5F9E01">
        
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perUser" />
        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <UIRef Id="WixUI_Minimal" />
        <WixVariable Id="WixUILicenseRtf" Value="Resources\License.rtf" />

        <Feature Id="ProductFeature" Title="FilterPlus" Level="1">
            <ComponentGroupRef Id="Revit2023Components" />
            <ComponentGroupRef Id="Revit2024Components" />
            <ComponentGroupRef Id="Revit2025Components" />
            <ComponentGroupRef Id="Revit2026Components" />
            <ComponentGroupRef Id="Revit2027Components" />
        </Feature>
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="AppDataFolder">
                <Directory Id="AutodeskDir" Name="Autodesk">
                    <Directory Id="RevitDir" Name="Revit">
                        <Directory Id="AddinsDir" Name="Addins">
                            <Directory Id="REVIT2023" Name="2023"><Directory Id="FOLDER2023" Name="FilterPlus"/></Directory>
                            <Directory Id="REVIT2024" Name="2024"><Directory Id="FOLDER2024" Name="FilterPlus"/></Directory>
                            <Directory Id="REVIT2025" Name="2025"><Directory Id="FOLDER2025" Name="FilterPlus"/></Directory>
                            <Directory Id="REVIT2026" Name="2026"><Directory Id="FOLDER2026" Name="FilterPlus"/></Directory>
                            <Directory Id="REVIT2027" Name="2027"><Directory Id="FOLDER2027" Name="FilterPlus"/></Directory>
                        </Directory>
                    </Directory>
                </Directory>
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <!-- Revit 2023 -->
        <ComponentGroup Id="Revit2023Components">
            <Component Id="Addin_2023" Guid="*" Directory="REVIT2023"><File Source="..\bin\Release.R23\publish\FilterPlus.addin" Id="Ad23"/></Component>
            <Component Id="Dlls_2023" Guid="*" Directory="FOLDER2023">
                <File Source="..\bin\Release.R23\publish\FilterPlus\FilterPlus.dll" Id="Dl23"/>
                <File Source="..\bin\Release.R23\publish\FilterPlus\Nice3point.Revit.Extensions.dll" Id="Ext23"/>
                <File Source="..\bin\Release.R23\publish\FilterPlus\Nice3point.Revit.Toolkit.dll" Id="Tlk23"/>
                <File Source="..\bin\Release.R23\publish\FilterPlus\CommunityToolkit.Mvvm.dll" Id="Mvvm23"/>
            </Component>
        </ComponentGroup>

        <!-- Revit 2024 -->
        <ComponentGroup Id="Revit2024Components">
