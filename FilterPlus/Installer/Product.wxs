                <File Source="..\bin\Release.R25\publish\FilterPlus\Nice3point.Revit.Toolkit.dll" Id="Tlk25"/>
                <File Source="..\bin\Release.R25\publish\FilterPlus\CommunityToolkit.Mvvm.dll" Id="Mvvm25"/>
            </Component>
