                <File Source="..\bin\Release.R26\publish\FilterPlus\Nice3point.Revit.Toolkit.dll" Id="Tlk26"/>
                <File Source="..\bin\Release.R26\publish\FilterPlus\CommunityToolkit.Mvvm.dll" Id="Mvvm26"/>
