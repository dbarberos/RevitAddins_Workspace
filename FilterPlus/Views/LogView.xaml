<Window x:Class="FilterPlus.Views.LogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:FilterPlus.ViewModels"
        Title="FilterPlus Debug Log" Height="400" Width="600"
        WindowStartupLocation="Manual"
        Topmost="True" Background="#1e1e1e">
    <Window.DataContext>
        <viewmodels:LogViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <ListBox ItemsSource="{Binding Logs}" Background="#252526" Foreground="#d4d4d4" BorderThickness="0" FontFamily="Consolas" FontSize="11">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="2"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>
    </Grid>
</Window>
